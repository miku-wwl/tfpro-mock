module "compute" {
  source = "../../modules/compute"

  subnet_id             = data.terraform_remote_state.shared.outputs.subnet_ids_by_zone[0]
  security_group_ids    = data.terraform_remote_state.shared.outputs.security_group_ids
  selected_tier         = var.security_tiers[0]
  archive_region        = var.archive.bucket_region
  observer_account      = data.terraform_remote_state.shared.outputs.observer_account_id

  # Defects include map-as-list, set indexing, an invalid object attribute,
  # a mismatched variable contract, and an undeclared module argument.
}
