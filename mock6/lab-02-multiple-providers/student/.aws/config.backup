[default]
region = us-east-1
output = json

[profile compute-admin]
role_arn = arn:aws:iam::000000000000:role/tfpro-final-compute-operator
source_profile = compute-origin
region = us-east-1
output = json

[profile identity-admin]
role_arn = arn:aws:iam::000000000000:role/tfpro-final-identity-operator
source_profile = identity-origin
region = us-east-1
output = json

[profile readonly-auditor]
role_arn = arn:aws:iam::000000000000:role/tfpro-final-readonly-auditor
source_profile = audit-origin
region = us-east-1
output = json
